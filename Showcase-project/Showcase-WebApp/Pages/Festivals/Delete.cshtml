@page "{id:int}"
@model Showcase_WebApp.Pages.Festivals.DeleteModel

<h1>Festival verwijderen</h1>

<p>Weet je zeker dat je dit festival wilt verwijderen?</p>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Festival.Name</h5>
        <p><strong>Locatie:</strong> @Model.Festival.Location</p>
        <p><strong>Datum:</strong> @Model.Festival.Date.ToString("dd-MM-yyyy")</p>
        <p><strong>Genre:</strong> @Model.Festival.Genre</p>
        <p>@Model.Festival.Description</p>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Verwijderen</button>
    <a asp-page="/Festivals/Index" class="btn btn-secondary">Annuleren</a>
</form>